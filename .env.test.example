# ========================================
# Foundry REST API Test Configuration
# ========================================
# Copy this file to .env.test and adjust values for your setup
#
# REQUIREMENTS:
# 1. A running relay server
# 2. One or more running Foundry VTT instances
# 3. Valid Foundry login credentials or an existing session

# ========================================
# REQUIRED: Relay Server Configuration
# ========================================
TEST_BASE_URL=http://localhost:3010

# API key for your relay account.
# OPTIONAL — if omitted, the test suite registers a fresh account at startup
# and deletes it when all tests finish (ephemeral mode). Requires registration
# to be enabled on the server (DISABLE_REGISTRATION must not be set).
# Set this to reuse a persistent account across test runs instead.
# TEST_API_KEY=your-relay-api-key-here

# ========================================
# REQUIRED: Foundry Instances
# ========================================
# Point to your already running Foundry instances
# Format: FOUNDRY_V{VERSION}_URL=http://localhost:{PORT}

FOUNDRY_V12_URL=http://localhost:30012
FOUNDRY_V13_URL=http://localhost:30013
# FOUNDRY_V14_URL=http://localhost:30014

# Which versions to test (comma-separated, must match URL versions above)
TEST_FOUNDRY_VERSIONS=12,13

# ========================================
# Session Mode Configuration
# ========================================
# Set to 'true' to use an existing Foundry session instead of creating a headless one
# This is faster for testing and doesn't require browser automation
# USE_EXISTING_SESSION=true

# If USE_EXISTING_SESSION=true, provide your existing client IDs per version
# You can get these from your browser's Foundry console or the relay /clients endpoint
# Format: TEST_CLIENT_ID_V{version}={clientId}
# TEST_CLIENT_ID_V12=foundry-xyz789abc012
# TEST_CLIENT_ID_V13=foundry-xyz789abc012
# TEST_CLIENT_ID_V14=foundry-xyz789abc012

# ========================================
# Headless Session Configuration (if USE_EXISTING_SESSION=false)
# ========================================
# Your Foundry login credentials for headless session creation
FOUNDRY_USERNAME=Gamemaster
FOUNDRY_PASSWORD=password

# Default world name to use if version-specific world not specified
TEST_DEFAULT_WORLD=test-world

# Version-specific world names (optional)
# If not set, will use TEST_DEFAULT_WORLD for all versions
FOUNDRY_V12_WORLD=test-world-v12
FOUNDRY_V13_WORLD=test-world-v13
# FOUNDRY_V14_WORLD=test-world-v14

# ========================================
# Auth Endpoint Tests (Optional)
# ========================================
# Relay account credentials for testing auth endpoints (login, change-password, etc.)
# If not set, auth endpoint tests that require credentials will be skipped.
# TEST_USER_EMAIL=admin@example.com
# TEST_USER_PASSWORD=YourPassword1

# ========================================
# Admin Endpoint Tests (Optional)
# ========================================
# Relay account credentials for testing admin endpoints (login, change-password, etc.)
# If not set, admin endpoint tests that require credentials will be skipped.
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=YourPassword1

# ========================================
# Permission Filtering Tests (Optional)
# ========================================
# To test userId permission filtering, create a non-GM player in your Foundry world
# and provide their user ID or username here. Without this, only invalid-userId
# error handling tests will run.
# TEST_PLAYER_USER_ID_V12=Player1
# TEST_PLAYER_USER_ID_V13=Player1
# TEST_PLAYER_USER_ID_V14=Player1

# ========================================
# Debug Configuration
# ========================================
# Capture browser console output from headless sessions to data/browser-logs/
# Passed to the relay server via the start-session request body
# Values: "error" (errors only), "warn" (errors + warnings), "debug" (all output)
CAPTURE_BROWSER_CONSOLE=warn

# Skip entity cleanup after tests (useful for inspecting test state in the DB)
# Default: false
# SKIP_CLEANUP=false