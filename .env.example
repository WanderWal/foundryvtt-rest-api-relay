# ========================================
# FoundryVTT REST API Relay — Server Configuration
# ========================================
# Copy this file to .env and adjust values for your setup.

# ========================================
# Core
# ========================================

# Server port
# Default: 3010
PORT=3010

# Environment mode ("development" or "production")
# Production enables SSL for PostgreSQL connections
# Default: development (Docker compose files set this to "production" automatically)
# APP_ENV=production

# Database backend: "sqlite" (default, self-hosted) or "postgres" (production)
# Default: sqlite
DB_TYPE=sqlite

# PostgreSQL connection string (required when DB_TYPE=postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/foundryvtt_api

# Log level: "debug", "info", "warn", "error"
# Default: info
LOG_LEVEL=info

# ========================================
# Auth
# ========================================

# Auto-create an admin user on startup (optional)
# If set, registers this user if they don't already exist
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=SecurePassword1

# Disable new user registration (for private/staging environments)
# Default: false
DISABLE_REGISTRATION=false

# AES-256 encryption key for encrypting Foundry credentials stored on scoped API keys.
# Optional — auto-generated on first startup and saved to <DATA_DIR>/.secrets.env.
# If this key is lost or rotated, users will need to re-enter their stored Foundry credentials.
# Generate with: openssl rand -hex 32
# CREDENTIALS_ENCRYPTION_KEY=

# ========================================
# Admin Authentication & Security
# ========================================

# JWT secret for admin authentication.
# Optional — auto-generated on first startup and saved to <DATA_DIR>/.secrets.env.
# Set this explicitly if you want stable tokens across deployments (e.g. blue/green).
# Generate with: openssl rand -base64 32
# ADMIN_JWT_SECRET=

# Comma-separated IP allowlist for admin endpoints (optional)
# If set, only these IPs can access admin routes
# Example: 127.0.0.1,192.168.1.100
# ADMIN_ALLOWED_IPS=127.0.0.1

# Internal port for admin panel (separate from main API port)
# Default: 3011
# ADMIN_INTERNAL_PORT=3011

# Admin session max duration in hours
# Default: 8 (in dev mode the full window is used as the token TTL — no re-login within this window)
# ADMIN_SESSION_MAX_HOURS=24

# Admin audit log retention in days
# Default: 90
# ADMIN_AUDIT_LOG_RETENTION_DAYS=90

# Rate limit for admin login attempts per IP (15-minute window)
# Default: 10
# ADMIN_LOGIN_RATE_LIMIT=10

# Failed login threshold before account lockout
# Default: 5
# ADMIN_LOCKOUT_THRESHOLD=5

# Account lockout duration in minutes
# Default: 15
# ADMIN_LOCKOUT_MINUTES=15

# Enable Secure cookie flag and __Host- prefix for the admin panel cookie.
# Set to true when your admin panel is served over HTTPS.
# Default: false (plain HTTP deployments work without this)
# ADMIN_SECURE_COOKIES=true

# ========================================
# Rate Limiting
# ========================================

# Max requests per IP for auth endpoints (register, login, regenerate-key)
# Window: 15 minutes
# Default: 5
# AUTH_RATE_LIMIT=5

# Max requests per IP for password reset endpoints
# Window: 1 hour
# Default: 3
# PASSWORD_RESET_RATE_LIMIT=3

# Max requests per IP for account management endpoints (change-password, export-data, delete account)
# Window: 1 hour
# Default: 10
# ACCOUNT_MGMT_RATE_LIMIT=10

# Max requests per IP for relay-to-Foundry pairing attempts
# Window: 15 minutes
# Default: 10
# PAIRING_RATE_LIMIT=10

# Max key-request submissions per IP (scoped key approval flow)
# Window: 15 minutes
# Default: 20
# KEY_REQUEST_RATE_LIMIT=20

# Max active-connection probe requests per IP
# Window: 1 minute
# Default: 60
# PROBE_RATE_LIMIT=60

# Return raw password reset token in the forgot-password response (for testing only!)
# NEVER enable this in production — it bypasses the email verification step.
# Default: false
# RETURN_RESET_TOKEN=true

# ========================================
# Self-Hosting vs. Billing Mode
# ========================================
# The relay automatically detects whether billing is enabled based on whether
# STRIPE_SECRET_KEY is set:
#
#   No STRIPE_SECRET_KEY → self-hosted mode
#     • Subscription UI hidden on the dashboard (no "Free plan" badge, no upgrade CTA)
#     • Request limits default to 0 (unlimited) — see below
#
#   STRIPE_SECRET_KEY set → commercial mode
#     • Full subscription UI shown
#     • Set MONTHLY_REQUEST_LIMIT to enforce a free-tier monthly quota
#
# The Docker image defaults the monthly limit to 0 (unlimited). Override here
# or in your compose file if you want to enforce a quota on self-hosted users.

# ========================================
# API Usage Limits
# ========================================
# A value of 0 means unlimited (no limit enforced).
# The Docker image defaults to 0 for self-hosted deployments.

# Monthly API request limit for free-tier users (old name: FREE_API_REQUESTS_LIMIT)
# Default in Docker: 0 (unlimited). Commercial hosted relay: 5,000.
# Paid subscribers (Stripe active) are always unlimited regardless of this value.
# MONTHLY_REQUEST_LIMIT=5000

# Per-minute API request limit per API key
# Set to 0 to disable. Default: 300
# PER_MINUTE_REQUEST_LIMIT=300

# ========================================
# Stripe (Subscription Billing)
# ========================================
# Stripe is disabled when STRIPE_SECRET_KEY is not set (the self-hosted default).
# Use sk_test_ keys for development, sk_live_ for production.

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Shared Stripe Customer Portal URL (from Stripe Dashboard > Settings > Customer portal)
# STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...

# Base URL for your relay's public address. Used for email links (password reset,
# email verification, key approval), pairing URLs, and Stripe checkout redirects.
# Default: https://foundryrestapi.com (correct for the hosted relay; set this for self-hosted)
# Example: http://192.168.1.42:3010 for LAN-only, or https://relay.yourdomain.com for internet-facing
# FRONTEND_URL=https://relay.yourdomain.com

# ========================================
# Redis (Multi-Instance Routing)
# ========================================
# Optional. Enables cross-instance client routing for multi-instance deployments.
# Automatically disabled when DB_TYPE is "sqlite".

# REDIS_URL=redis://default:password@host:6379
# REDIS_ENABLED=true

# ========================================
# Email (Password Reset, Notifications)
# ========================================
# Required for password reset emails. If not configured, reset tokens
# are logged to the console instead.

# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Foundry REST API <noreply@example.com>
# SMTP_SECURE=false

# ========================================
# WebSocket Tuning
# ========================================

# Keepalive ping interval for WebSocket connections (ms)
# Default: 20000
# WEBSOCKET_PING_INTERVAL_MS=20000

# Interval to check for and remove dead client connections (ms)
# Default: 15000
# CLIENT_CLEANUP_INTERVAL_MS=15000

# How long (seconds) to cache API key lookups in memory to reduce DB load
# Default: 30
# AUTH_CACHE_TTL_SECONDS=30

# ========================================
# Data / Storage
# ========================================

# Directory for persistent data (SQLite DB, browser logs, etc.)
# Resolved to an absolute path at startup. Default: "data" (relative to server CWD)
# DATA_DIR=data

# Override the SQLite database file path (only used when DB_TYPE=sqlite)
# Default: <DATA_DIR>/relay.db
# SQLITE_PATH=/custom/path/relay.db

# ========================================
# Headless Sessions (Puppeteer/Chrome)
# ========================================

# Allow headless browser sessions (set to false to completely disable)
# Default: true
# ALLOW_HEADLESS=true

# Max concurrent headless browser sessions. 0 = no limit.
# Default: 0
# MAX_HEADLESS_SESSIONS=0

# Max interactive sheet sessions per scoped API key
# Default: 3
# MAX_INTERACTIVE_SESSIONS_PER_KEY=3

# Max JSON request body size in MB (applies to all JSON API calls)
# Default: 250
# MAX_JSON_BODY_SIZE_MB=250

# Max file upload size in MB (applies to file upload endpoints)
# Default: 250
# MAX_UPLOAD_SIZE_MB=250

# Headless session inactivity timeout in seconds (session ends if no API call in this window)
# Set to 0 to never time out due to inactivity.
# Default: 600 (10 minutes)
# HEADLESS_SESSION_TIMEOUT=600

# Path to Chrome/Chromium executable (auto-detected if not set)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Headless rendering backend (auto-detected by default)
# auto: picks nvidia, gpu (Intel/AMD), xvfb, or swiftshader based on what's available
# gpu: Intel/AMD via Mesa/DRI  |  nvidia: NVIDIA hardware via ANGLE Vulkan + native Vulkan ICD
# xvfb: Mesa software via virtual display  |  swiftshader: Chrome built-in software WebGL
# CHROME_GPU_MODE=auto

# Capture browser console output from headless sessions
# Values: "error" (errors only), "warn" (errors + warnings), "debug" (all)
# Logs saved to data/browser-logs/
# CAPTURE_BROWSER_CONSOLE=warn

# Require paid subscription for headless session creation
# Default: false
# REQUIRE_PAID_HEADLESS=false

# ========================================
# Algolia DocSearch (Documentation Site)
# ========================================
# Powers the search bar on the Docusaurus docs site.
# Get these from https://www.algolia.com after creating an app.

# ALGOLIA_APP_ID=S6TB6KX8K6
# ALGOLIA_SEARCH_API_KEY=54cb86f54a675d0bd897ce1e074b922c
# ALGOLIA_INDEX_NAME=FVTT REST API Docs crawler
